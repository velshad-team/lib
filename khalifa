-- [[ وظيفة جلب الـ Props ]] --
local function getProps()
    local p = {}
    for _, obj in ipairs(WorkspaceCom:GetChildren()) do
        if obj.Name:match("^Prop") and obj:FindFirstChild("SetCurrentCFrame") then
            table.insert(p, obj.SetCurrentCFrame)
        end
    end
    return p
end

-- [[ محرك الـ Bang ]] --
local function startBang()
    if State.Connection then State.Connection:Disconnect() end
    task.spawn(function()
        while State.Active do
            State.TogglePos = not State.TogglePos
            task.wait(State.Speed)
        end
    end)
    State.Connection = RunService.Heartbeat:Connect(function()
        if not State.Active or not State.Target then return end
        local props = getProps()
        local targetPlayer = Players:FindFirstChild(State.Target)
        if targetPlayer and targetPlayer.Character and targetPlayer.Character:FindFirstChild("HumanoidRootPart") then
            local hrp = targetPlayer.Character.HumanoidRootPart
            local offset = State.TogglePos and 0.8 or 2.8
            for i, remote in ipairs(props) do
                local targetCF = hrp.CFrame * CFrame.new(0, -1, offset) * CFrame.Angles(math.rad(90), 0, 0)
                task.spawn(function() pcall(function() remote:InvokeServer(targetCF) end) end)
            end
        end
    end)
end

-- [[ تحديث قائمة اللاعبين ]] --
local function updateUIList()
    for _, child in ipairs(PlayerList:GetChildren()) do
        if child:IsA("TextButton") then child:Destroy() end
    end
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer then
            local pBtn = Instance.new("TextButton", PlayerList)
            pBtn.Size = UDim2.new(0.95, 0, 0, 35)
            pBtn.Text = p.Name
            pBtn.BackgroundColor3 = (State.Target == p.Name) and Color3.fromRGB(150, 0, 255) or Color3.fromRGB(45, 45, 50)
            pBtn.TextColor3 = Color3.fromRGB(255, 255, 255)
            pBtn.Font = Enum.Font.Gotham
            pBtn.TextSize = 12
            Instance.new("UICorner", pBtn)
            pBtn.MouseButton1Click:Connect(function()
                State.Target = p.Name
                ActionBtn.Text = "ACTIVATE ON: " .. p.Name:upper()
                ActionBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
                updateUIList()
            end)
        end
    end
    PlayerList.CanvasSize = UDim2.new(0, 0, 0, #Players:GetPlayers() * 40)
end

-- [[ تشغيل النظام ]] --
ActionBtn.MouseButton1Click:Connect(function()
    if not State.Target then return end
    State.Active = not State.Active
    if State.Active then
        ActionBtn.Text = "SYSTEM ONLINE [RUNNING]"
        ActionBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 50)
        startBang()
    else
        ActionBtn.Text = "ACTIVATE ON: " .. State.Target:upper()
        ActionBtn.BackgroundColor3 = Color3.fromRGB(180, 0, 0)
        if State.Connection then State.Connection:Disconnect() end
        pcall(function() ClearPropsRemote:FireServer("ClearAllProps") end)
    end
end)

-- [[ نظام سحب الواجهة بالماوس ]] --
local dragStart, startPos, dragging
Main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then
        dragging = true
        dragStart = input.Position
        startPos = Main.Position
    end
end)
UserInputService.InputChanged:Connect(function(input)
    if dragging and input.UserInputType == Enum.UserInputType.MouseMovement then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UserInputService.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 then dragging = false end
end)

updateUIList()
Players.PlayerAdded:Connect(updateUIList)
Players.PlayerRemoving:Connect(updateUIList)

print("KHALIFA GUI V35: ACTIVATED")
