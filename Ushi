    MinimizeBtn.TextSize = 14
    MinimizeBtn.Parent = TopBar
    CreateCorner(MinimizeBtn, UDim.new(0, 6))
    
    local Sidebar = Instance.new("Frame")
    Sidebar.Name = "Sidebar"
    Sidebar.Size = UDim2.new(0, 130, 1, -45)
    Sidebar.Position = UDim2.new(0, 0, 0, 45)
    Sidebar.BackgroundTransparency = 1
    Sidebar.Parent = MainFrame
    
    local TabScroll = Instance.new("ScrollingFrame")
    TabScroll.Name = "TabScroll"
    TabScroll.Size = UDim2.new(1, 0, 1, 0)
    TabScroll.BackgroundTransparency = 1
    TabScroll.ScrollBarThickness = 2
    TabScroll.ScrollBarImageColor3 = Theme.Accent
    TabScroll.CanvasSize = UDim2.new()
    TabScroll.Parent = Sidebar
    
    local TabLayout = Instance.new("UIListLayout")
    TabLayout.Padding = UDim.new(0, 5)
    TabLayout.Parent = TabScroll
    
    local ContentArea = Instance.new("Frame")
    ContentArea.Name = "Content"
    ContentArea.Size = UDim2.new(1, -140, 1, -55)
    ContentArea.Position = UDim2.new(0, 135, 0, 50)
    ContentArea.BackgroundTransparency = 1
    ContentArea.Parent = MainFrame
    
    local ContentScroll = Instance.new("ScrollingFrame")
    ContentScroll.Name = "ContentScroll"
    ContentScroll.Size = UDim2.new(1, 0, 1, 0)
    ContentScroll.BackgroundTransparency = 1
    ContentScroll.ScrollBarThickness = 4
    ContentScroll.ScrollBarImageColor3 = Theme.Accent
    ContentScroll.CanvasSize = UDim2.new()
    ContentScroll.Parent = ContentArea
    
    local ContentLayout = Instance.new("UIListLayout")
    ContentLayout.Padding = UDim.new(0, 6)
    ContentLayout.Parent = ContentScroll
    
    local Padding = Instance.new("UIPadding")
    Padding.PaddingTop = UDim.new(0, 5)
    Padding.PaddingBottom = UDim.new(0, 10)
    Padding.PaddingLeft = UDim.new(0, 5)
    Padding.PaddingRight = UDim.new(0, 5)
    Padding.Parent = ContentScroll
    
    local Tabs = {}
    local ActiveTab = nil
    
    local function Minimize()
        MainFrame.Visible = not MainFrame.Visible
    end
    
    ToggleBtn.MouseButton1Click:Connect(Minimize)
    
    CloseBtn.MouseButton1Click:Connect(function()
        ScreenGui:Destroy()
    end)
    
    local Minimized = false
    MinimizeBtn.MouseButton1Click:Connect(function()
        if not Minimized then
            CreateTween(MainFrame, "Size", UDim2.new(0, MainFrame.Size.X.Offset, 0, 45), 0.3, true)
            Sidebar.Visible = false
            ContentArea.Visible = false
            MinimizeBtn.Text = "+"
            Minimized = true
        else
            Sidebar.Visible = true
            ContentArea.Visible = true
            CreateTween(MainFrame, "Size", Size, 0.3, true)
            MinimizeBtn.Text = "-"
            Minimized = false
        end
    end)
    
    local Window = {}
    
    function Window:MakeTab(TabConfig)
        local TabName = TabConfig.Name or "Tab"
        local TabIcon = TabConfig.Icon
        
        local TabBtn = Instance.new("TextButton")
        TabBtn.Name = TabName
        TabBtn.Size = UDim2.new(1, -10, 0, 32)
        TabBtn.Position = UDim2.new(0, 5, 0, 0)
        TabBtn.BackgroundColor3 = Theme.Dark
        TabBtn.Text = TabName
        TabBtn.Font = Enum.Font.GothamBold
        TabBtn.TextSize = 11
        TabBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
        TabBtn.Parent = TabScroll
        CreateCorner(TabBtn)
        
        if TabIcon then
            local Icon = Instance.new("ImageLabel")
            Icon.Size = UDim2.new(0, 16, 0, 16)
            Icon.Position = UDim2.new(0, 8, 0.5, 0)
            Icon.AnchorPoint = Vector2.new(0, 0.5)
            Icon.BackgroundTransparency = 1
            Icon.Image = TabIcon
            Icon.Parent = TabBtn
            
            TabBtn.Text = "    " .. TabName
        end
        
        local Indicator = Instance.new("Frame")
        Indicator.Size = UDim2.new(0, 3, 0.6, 0)
        Indicator.Position = UDim2.new(0, 2, 0.2, 0)
        Indicator.BackgroundColor3 = Theme.Accent
        Indicator.BorderSizePixel = 0
        Indicator.Visible = false
        Indicator.Parent = TabBtn
        CreateCorner(Indicator, UDim.new(0.5, 0))
        
        local TabContent = Instance.new("ScrollingFrame")
        TabContent.Name = TabName .. "Content"
        TabContent.Size = UDim2.new(1, 0, 1, 0)
        TabContent.BackgroundTransparency = 1
        TabContent.ScrollBarThickness = 0
        TabContent.CanvasSize = UDim2.new()
        TabContent.Visible = false
        TabContent.Parent = ContentArea
        
        local TabContentLayout = Instance.new("UIListLayout")
        TabContentLayout.Padding = UDim.new(0, 6)
        TabContentLayout.Parent = TabContent
        
        local TabPadding = Instance.new("UIPadding")
        TabPadding.PaddingTop = UDim.new(0, 5)
        TabPadding.PaddingBottom = UDim.new(0, 10)
        TabPadding.PaddingLeft = UDim.new(0, 5)
        TabPadding.PaddingRight = UDim.new(0, 5)
        TabPadding.Parent = TabContent
        
        local function Activate()
            if ActiveTab then
                CreateTween(ActiveTab.Btn, "BackgroundColor3", Theme.Dark, 0.3)
                ActiveTab.Btn.TextColor3 = Color3.fromRGB(180, 180, 180)
                ActiveTab.Indicator.Visible = false
                ActiveTab.Content.Visible = false
            end
            
            CreateTween(TabBtn, "BackgroundColor3", Color3.fromRGB(60, 0, 0), 0.3)
            TabBtn.TextColor3 = Theme.Accent
            Indicator.Visible = true
            TabContent.Visible = true
            ActiveTab = {Btn = TabBtn, Indicator = Indicator, Content = TabContent}
            
            TabContent.CanvasSize = UDim2.new(0, 0, 0, TabContentLayout.AbsoluteContentSize.Y + 20)
        end
        
        TabBtn.MouseButton1Click:Connect(Activate)
        
        if not ActiveTab then Activate() end
        
        TabScroll.CanvasSize = UDim2.new(0, 0, 0, TabLayout.AbsoluteContentSize.Y + 10)
        
        local Tab = {}
        
        function Tab:AddSection(Text)
            return CreateLabel(TabContent, {
                Text = Text,
                Size = 14,
                Color = Theme.Accent,
                Alignment = Enum.TextXAlignment.Center
            })
        end
        
        function Tab:AddLabel(Text)
            return CreateLabel(TabContent, {Text = Text})
        end
        
        function Tab:AddButton(Config)
            return CreateButton(TabContent, Config)
        end
        
        function Tab:AddToggle(Config)
            return CreateToggle(TabContent, Config)
        end
        
        function Tab:AddSlider(Config)
            return CreateSlider(TabContent, Config)
        end
        
        function Tab:AddDropdown(Config)
            return CreateDropdown(TabContent, Config)
        end
        
        function Tab:AddTextBox(Config)
            return CreateTextBox(TabContent, Config)
        end
        
        return Tab
    end
    
    function Window:Destroy()
        ScreenGui:Destroy()
    end
    
    function Window:Minimize()
        Minimize()
    end
    
    return Window
end

return USHINOU
