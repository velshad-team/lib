    if not Config.Active then return end
    
    local LP = game.Players.LocalPlayer
    local Char = LP.Character
    if not Char or not Char:FindFirstChild("HumanoidRootPart") then return end
    
    local Root = Char.HumanoidRootPart
    local Tool = Char:FindFirstChildOfClass("Tool")
    
    -- نظام "الثبات الكوني": يمنع تحركك أو طيرانك نهائياً
    Root.Velocity = Vector3.new(Root.Velocity.X, 0, Root.Velocity.Z)
    Root.RotVelocity = Vector3.new(0, 0, 0)

    Angle = Angle + (Config.SpinSpeed / 10)
    local TargetPos = Vector3.new(math.cos(Angle) * Config.Distance, Config.Height, math.sin(Angle) * Config.Distance)

    -- تحويل الكنبة لدرع طاقة FE
    if Tool and Tool:FindFirstChild("Handle") then
        Tool.Grip = CFrame.new(TargetPos)
    end

    -- رادار المسح والإبادة الفورية
    for _, p in pairs(game.Players:GetPlayers()) do
        if p ~= LP and p.Character and p.Character:FindFirstChild("HumanoidRootPart") then
            local TRoot = p.Character.HumanoidRootPart
            local dist = (Root.Position - TRoot.Position).Magnitude
            
            if dist <= Config.Range then
                pcall(function()
                    -- ميزة "الجاذبية القسرية": سحب الهدف لمركز الانفجار
                    if dist > (Config.Distance + 2) then
                        TRoot.Velocity = (Root.Position + TargetPos - TRoot.Position).Unit * 250
                    end
                    
                    -- إعدام FE (Fling)
                    if dist <= (Config.Distance + 5) then
                        TRoot.CanCollide = false
                        TRoot.Velocity = Vector3.new(0, Config.KillPower, 0)
                        TRoot.RotVelocity = Vector3.new(Config.KillPower, Config.KillPower, Config.KillPower)
                    end
                end)
            end
        end
    end
end)

