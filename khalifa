local function HeadChat(player, text)
    if player.Character and player.Character:FindFirstChild("Head") then
        local Head = player.Character.Head
        if Head:FindFirstChild("9MART_Chat") then Head["9MART_Chat"]:Destroy() end
        
        local BBG = Instance.new("BillboardGui", Head)
        BBG.Name = "9MART_Chat"
        BBG.Size = UDim2.new(0, 200, 0, 50)
        BBG.ExtentsOffset = Vector3.new(0, 3.5, 0)
        BBG.AlwaysOnTop = true
        
        local F = Instance.new("Frame", BBG)
        F.Size = UDim2.new(1, 0, 1, 0)
        F.BackgroundColor3 = Color3.new(0,0,0)
        F.BackgroundTransparency = 0.4
        Instance.new("UICorner", F)
        
        local L = Instance.new("TextLabel", F)
        L.Size = UDim2.new(1, 0, 1, 0)
        L.Text = text
