local function CreateTween(inst, prop, val, time)
    TweenService:Create(inst, TweenInfo.new(time or 0.3, Enum.EasingStyle.Quint), {[prop] = val}):Play()
end

local function MakeDrag(frame, handle)
    local dragging, dragStart, startPos
    handle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(input)
        if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = false
        end
    end)
end

local function AddMovingBorder(parent, thickness)
    local stroke = Instance.new("UIStroke")
    stroke.Parent = parent
    stroke.Thickness = thickness or 2.5
    stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    local gradient = Instance.new("UIGradient")
    gradient.Parent = stroke
    gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, Color3.fromRGB(50, 0, 0)),
        ColorSequenceKeypoint.new(0.5, USHINOU.Theme.Accent),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(50, 0, 0))
    })
    local rot = 0
    RunService.RenderStepped:Connect(function(delta)
        rot = rot + delta * 150
        if rot >= 360 then rot = 0 end
        gradient.Rotation = rot
    end)
end

local function CreateParticles(mainFrame)
    for i = 1, 15 do
        local p = Instance.new("Frame")
        p.Size = UDim2.new(0, 2, 0, 2)
        p.BackgroundColor3 = USHINOU.Theme.Accent
        p.BackgroundTransparency = 0.5
        p.Position = UDim2.new(math.random(), 0, math.random(), 0)
        p.Parent = mainFrame
        p.ZIndex = 2
        Instance.new("UICorner", p).CornerRadius = UDim.new(1, 0)
        task.spawn(function()
            while p.Parent do
                local target = UDim2.new(math.random(), 0, math.random(), 0)
                local t = TweenService:Create(p, TweenInfo.new(math.random(5,10), Enum.EasingStyle.Linear), {Position = target, BackgroundTransparency = 0.8})
                t:Play()
                t.Completed:Wait()
                p.BackgroundTransparency = 0.5
            end
        end)
    end
end

