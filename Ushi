    RunService.RenderStepped:Connect(function()
        local t = tick()
        local moveX = math.sin(t * 0.3) * 40
        local moveY = math.cos(t * 0.3) * 40
        local zoom = 1.5 + math.sin(t * 0.15) * 0.05
        BackgroundImage.Position = UDim2.new(-0.25, moveX, -0.25, moveY)
        BackgroundImage.Size = UDim2.new(zoom, 0, zoom, 0)
    end)

    local ActiveTab = nil

    local function CreateTab(name)
        local button = Instance.new("TextButton")
        button.Size = UDim2.new(1, -10, 0, 35)
        button.Position = UDim2.new(0, 5, 0, 0)
        button.BackgroundColor3 = USHINOU.Theme.Dark
        button.Text = name
        button.Font = Enum.Font.GothamBold
        button.TextSize = 12
        button.TextColor3 = USHINOU.Theme.InActiveTab
        button.BackgroundTransparency = 1
        button.TextTransparency = 1
        button.Parent = TabScroll
        CreateCorner(button)

        local indicator = Instance.new("Frame")
        indicator.Size = UDim2.new(0, 3, 0.6, 0)
        indicator.Position = UDim2.new(0, 2, 0.2, 0)
        indicator.BackgroundColor3 = USHINOU.Theme.Accent
        indicator.BorderSizePixel = 0
        indicator.Visible = false
        indicator.Parent = button
        CreateCorner(indicator, UDim.new(0.5, 0))

        local tabStroke = AddMovingBorder(button, 1.2)
        tabStroke.Enabled = false

        local content = Instance.new("ScrollingFrame")
        content.Size = UDim2.new(1, 0, 1, 0)
        content.BackgroundTransparency = 1
        content.ScrollBarThickness = 0
        content.CanvasSize = UDim2.new()
        content.Visible = false
        content.Parent = ContentArea

        local layout = Instance.new("UIListLayout")
        layout.Padding = UDim.new(0, 6)
        layout.Parent = content

        local padding = Instance.new("UIPadding")
        padding.PaddingTop = UDim.new(0, 5)
        padding.PaddingBottom = UDim.new(0, 10)
        padding.PaddingLeft = UDim.new(0, 5)
        padding.PaddingRight = UDim.new(0, 5)
        padding.Parent = content

        local function activate()
            if ActiveTab then
                CreateTween(ActiveTab.button, "BackgroundColor3", USHINOU.Theme.Dark, 0.3)
                ActiveTab.button.TextColor3 = USHINOU.Theme.InActiveTab
                ActiveTab.indicator.Visible = false
                ActiveTab.tabStroke.Enabled = false
                ActiveTab.content.Visible = false
            end
            CreateTween(button, "BackgroundColor3", Color3.fromRGB(60, 0, 0), 0.3)
            button.TextColor3 = USHINOU.Theme.Accent
            indicator.Visible = true
            tabStroke.Enabled = true
            content.Visible = true
            ActiveTab = {button = button, indicator = indicator, content = content, tabStroke = tabStroke}
            content.CanvasSize = UDim2.new(0, 0, 0, layout.AbsoluteContentSize.Y + 20)
        end

        button.MouseButton1Click:Connect(activate)

        if not ActiveTab then
            task.delay(0.8, function()
                CreateTween(button, "BackgroundTransparency", 0, 0.3)
                CreateTween(button, "TextTransparency", 0, 0.3)
                activate()
            end)
        else
            task.delay(0.8, function()
                CreateTween(button, "BackgroundTransparency", 0.7, 0.3)
                CreateTween(button, "TextTransparency", 0.2, 0.3)
            end)
        end

        TabScroll.CanvasSize = UDim2.new(0, 0, 0, TabLayout.AbsoluteContentSize.Y + 10)

        local Tab = {}

        function Tab:AddSection(text)
            return CreateLabel(content, {Text = text, Size = 14, Color = USHINOU.Theme.Accent, Alignment = Enum.TextXAlignment.Center})
        end

        function Tab:AddLabel(text)
            return CreateLabel(content, {Text = text})
        end

        function Tab:AddButton(config)
            return CreateButton(content, config)
        end

        function Tab:AddToggle(config)
            return CreateToggle(content, config)
        end

        function Tab:AddSlider(config)
            return CreateSlider(content, config)
        end

        function Tab:AddDropdown(config)
            return CreateDropdown(content, config)
        end

        function Tab:AddTextBox(config)
            return CreateTextBox(content, config)
        end

        function Tab:AddKeybind(config)
            return CreateKeybind(content, config)
        end

        function Tab:AddColorPicker(config)
            return CreateColorPicker(content, config)
        end

        function Tab:AddParagraph(config)
            return CreateParagraph(content, config)
        end

        function Tab:AddDiscordInvite(config)
            return CreateDiscordInvite(content, config)
        end

        return Tab
    end

    local Window = {}

    function Window:MakeTab(tabConfig)
        return CreateTab(tabConfig.Name or "Tab")
    end

    function Window:Destroy()
        CreateTween(MainFrame, "Size", UDim2.new(0, 0, 0, 0), 0.5, true)
        CreateTween(MainFrame, "BackgroundTransparency", 1, 0.5)
        task.wait(0.5)
        ScreenGui:Destroy()
    end

    function Window:Minimize()
        MainFrame.Visible = not MainFrame.Visible
    end

    MakeDrag(MainFrame, Header)

    local isMinimized = false
    MinimizeBtn.MouseButton1Click:Connect(function()
        if not isMinimized then
            CreateTween(MainFrame, "Size", UDim2.new(0, Size.X.Offset, 0, 50), 0.4, true)
            Sidebar.Visible = false
            ContentArea.Visible = false
            MinimizeBtn.Text = "+"
            isMinimized = true
        else
            Sidebar.Visible = true
            ContentArea.Visible = true
            CreateTween(MainFrame, "Size", Size, 0.4, true)
            MinimizeBtn.Text = "—"
            isMinimized = false
        end
    end)

    CloseBtn.MouseButton1Click:Connect(function()
        CreateTween(MainFrame, "Size", UDim2.new(0, 0, 0, 0), 0.5, true)
        CreateTween(MainFrame, "BackgroundTransparency", 1, 0.5)
        task.wait(0.5)
        ScreenGui:Destroy()
    end)

    ToggleBtn.MouseButton1Click:Connect(function()
        if MainFrame.Visible then
            MainFrame.Visible = false
        else
            MainFrame.Visible = true
            CreateTween(MainFrame, "Size", Size, 0.4, true)
        end
    end)

    UserInputService.InputBegan:Connect(function(input, processed)
        if not processed and input.KeyCode == Enum.KeyCode.RightShift then
            if MainFrame.Visible then
                MainFrame.Visible = false
            else
                MainFrame.Visible = true
                CreateTween(MainFrame, "Size", Size, 0.4, true)
            end
        end
    end)

    task.spawn(function()
        MainFrame.Visible = true
        CreateTween(MainFrame, "Size", Size, 0.7, true)
        CreateTween(ToggleBtn, "ImageTransparency", 0, 0.5)
        task.wait(0.3)
        CreateTween(Header, "BackgroundTransparency", 0.2, 0.5)
        CreateTween(TitleLabel, "TextTransparency", 0, 0.5)
        task.wait(0.1)
        CreateTween(PlayerNameLabel, "TextTransparency", 0, 0.5)
        task.wait(0.1)
        CreateTween(CloseBtn, "TextTransparency", 0, 0.5)
        CreateTween(MinimizeBtn, "TextTransparency", 0, 0.5)
        CreateTween(ProfileImage, "ImageTransparency", 0, 0.5)
    end)

    return Window
end

return USHINOU
