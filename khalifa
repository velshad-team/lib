local function StartOblivion()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return end
    local root = char.HumanoidRootPart

    -- 1. الاحتلال الفيزيائي (تضخيم الإكسسوارات لدرجة العمى)
    -- ملاحظة: لازم تكون لابس قبعة أو شعر أو أي إكسسوار عشان يشتغل
    for _, v in pairs(char:GetChildren()) do
        if v:IsA("Accessory") and v:FindFirstChild("Handle") then
            local h = v.Handle
            h:BreakJoints() -- فكها من الرأس عشان نتحكم في حجمها
            h.Color = Color3.new(0, 0, 0)
            h.Material = Enum.Material.Neon
            h.Transparency = 0
            
            -- إضافة Mesh خارق لتجاوز حدود الحجم العادية
            local m = Instance.new("SpecialMesh", h)
            m.MeshType = Enum.MeshType.Brick -- مكعب
            
            RunService.RenderStepped:Connect(function()
                if capturing then
                    h.CanCollide = false
                    h.CFrame = root.CFrame
                    h.Size = Vector3.new(2048, 2048, 2048) -- الحجم الفيزيائي الأقصى
                    m.Scale = Vector3.new(50000, 50000, 50000) -- حجم ترليوني يغطي الماب وما وراء الماب
                end
            end)
        end
    end

    -- 2. ضباب "العدم" الكثيف (Particle Emitter)
    local att = Instance.new("Attachment", root)
    att.Name = "OBLIVION_PARTICLE"
    
    local p = Instance.new("ParticleEmitter", att)
    p.Texture = "rbxassetid://142384411"
    p.Size = NumberSequence.new(10000) -- حجم الجزيء الواحد يغطي مدينة
    p.Rate = 20000 -- كثافة قصوى (تسبب تعليق بصري للخصوم)
    p.Lifetime = NumberRange.new(50)
    p.Speed = NumberRange.new(0)
    p.Color = ColorSequence.new(Color3.new(0,0,0))
    p.Transparency = NumberSequence.new(0) -- أسود قاتم 100%
    p.ZOffset = 10 -- يخليه يظهر فوق أي واجهة (GUI) ثانية
    p.LockedToPart = false -- عشان يترك أثر في كل مكان تمشي فيه
end

