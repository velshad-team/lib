--- أدوات التنظيف ---
local function CleanTools()
    local char = LocalPlayer.Character
    if char then
        local couch = char:FindFirstChild("Chaos.Couch") or LocalPlayer.Backpack:FindFirstChild("Chaos.Couch")
        if couch then couch:Destroy() end
    end
    ReplicatedStorage:WaitForChild("RE"):WaitForChild("1Clea1rTool1s"):FireServer("ClearAllTools")
end

--- ميزة القتل الفوري (INSTANT KILL) ---
local function UltimateKill()
    local target = Players:FindFirstChild(getgenv().SelectedTarget)
    if not target or not target.Character then return end
    
    local char = LocalPlayer.Character
    local root = char:FindFirstChild("HumanoidRootPart")
    local tRoot = target.Character:FindFirstChild("HumanoidRootPart")
    
    if not root or not tRoot then return end
    
    local oldPos = root.CFrame
    CleanTools()
    task.wait(0.1)

    -- جلب الأداة
    ReplicatedStorage.RE:FindFirstChild("1Too1l"):InvokeServer("PickingTools", "Couch")
    local couch = LocalPlayer.Backpack:WaitForChild("Couch", 3)
    if not couch then return end
    
    couch.Parent = char
    task.wait(0.05)
    
    -- وضعية الهجوم: الالتصاق والتدوير النفاث
    local bodyVel = Instance.new("BodyAngularVelocity")
    bodyVel.AngularVelocity = Vector3.new(0, 9999, 0)
    bodyVel.MaxTorque = Vector3.new(0, math.huge, 0)
    bodyVel.P = 1250
    bodyVel.Parent = root

    local startTime = tick()
    while tick() - startTime < 3 do
        if not target.Character:FindFirstChild("Humanoid").Sit then
            root.CFrame = tRoot.CFrame * CFrame.new(0, 1.5, 0)
            VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.F, false, game)
        else
            -- إذا جلس الخصم، اقذفه إلى ما وراء الخريطة
            root.CFrame = CFrame.new(999999, 999999, 999999)
            task.wait(0.2)
            break
        end
        task.wait()
    end
    
    bodyVel:Destroy()
