local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer
local SelectedPlayer = nil

local function GetPlayer(String)
    local Found = {}
    for _, v in pairs(Players:GetPlayers()) do
        if v.Name:lower():sub(1, #String) == String:lower() then table.insert(Found, v) end
    end
    return Found
end

local function isItemInInventory(itemName)
    return LocalPlayer.Backpack:FindFirstChild(itemName) or (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild(itemName))
end

local function equipItem(itemName)
    local item = LocalPlayer.Backpack:FindFirstChild(itemName)
    if item and LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Humanoid") then
        LocalPlayer.Character.Humanoid:EquipTool(item)
    end
end

local function unequipItem(itemName)
    if LocalPlayer.Character then
        local item = LocalPlayer.Character:FindFirstChild(itemName)
        if item then item.Parent = LocalPlayer.Backpack end
    end
end

