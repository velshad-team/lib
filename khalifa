    Button.BackgroundColor3 = Active and Color3.new(0.5, 0, 0) or Color3.fromRGB(130, 0, 255)
    
    if Active then
        ShieldParts = GetParts()
    else
        ShieldParts = {}
    end
end)

RS.RenderStepped:Connect(function()
    if Active and LP.Character and LP.Character:FindFirstChild("HumanoidRootPart") then
        local Root = LP.Character.HumanoidRootPart
        sethiddenproperty(LP, "SimulationRadius", 1e10)
        
        local t = tick() * 60 -- سرعة دوران جنونية
        
        for i, p in pairs(ShieldParts) do
            if p and p.Parent then
                p.CanCollide = true
                -- منع قتل المستخدم (إلغاء التصادم معك)
                for _, charPart in pairs(LP.Character:GetDescendants()) do
                    if charPart:IsA("BasePart") then
                        local nc = charPart:FindFirstChild("NoCol"..p.Name) or Instance.new("NoCollisionConstraint", charPart)
                        nc.Name = "NoCol"..p.Name
                        nc.Part0 = charPart
                        nc.Part1 = p
                    end
                end
                
                -- حساب الزاوية (واحد يمين وواحد يسار لعمل فتحة بالنصف)
                local angle = t + (i * math.pi) 
                local offset = Vector3.new(math.cos(angle) * 4, 0, math.sin(angle) * 4)
                
                -- تطبيق الحركة (CFrame)
                -- الباب يكون واقف عمودياً ويدور حولك
                p.Velocity = Vector3.new(0, 100, 0) -- قوة صدم هائلة
                p.CFrame = Root.CFrame * CFrame.new(offset) * CFrame.Angles(0, -angle, math.rad(90))
            else
                ShieldParts = GetParts() -- إعادة البحث إذا اختفى الباب
            end
        end
    end
end)

