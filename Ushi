        TabBtn.BackgroundColor3 = USHINOU.Theme.Dark
        TabBtn.Text = TabName
        TabBtn.Font = Enum.Font.GothamBold
        TabBtn.TextSize = 12
        TabBtn.TextColor3 = Color3.fromRGB(180, 180, 180)
        TabBtn.BackgroundTransparency = 1
        TabBtn.TextTransparency = 1
        TabBtn.Parent = TabScroll
        CreateCorner(TabBtn)

        if TabIcon then
            local Icon = Instance.new("ImageLabel")
            Icon.Size = UDim2.new(0, 16, 0, 16)
            Icon.Position = UDim2.new(0, 8, 0.5, 0)
            Icon.AnchorPoint = Vector2.new(0, 0.5)
            Icon.BackgroundTransparency = 1
            Icon.Image = TabIcon
            Icon.ImageTransparency = 1
            Icon.Parent = TabBtn
            TabBtn.Text = "    " .. TabName
        end

        local Indicator = Instance.new("Frame")
        Indicator.Size = UDim2.new(0, 3, 0.6, 0)
        Indicator.Position = UDim2.new(0, 2, 0.2, 0)
        Indicator.BackgroundColor3 = USHINOU.Theme.Accent
        Indicator.BorderSizePixel = 0
        Indicator.Visible = false
        Indicator.Parent = TabBtn
        CreateCorner(Indicator, UDim.new(0.5, 0))

        local TabContent = Instance.new("ScrollingFrame")
        TabContent.Name = TabName .. "Content"
        TabContent.Size = UDim2.new(1, 0, 1, 0)
        TabContent.BackgroundTransparency = 1
        TabContent.ScrollBarThickness = 0
        TabContent.CanvasSize = UDim2.new()
        TabContent.Visible = false
        TabContent.Parent = ContentArea

        local TabContentLayout = Instance.new("UIListLayout")
        TabContentLayout.Padding = UDim.new(0, 6)
        TabContentLayout.Parent = TabContent

        local TabPadding = Instance.new("UIPadding")
        TabPadding.PaddingTop = UDim.new(0, 5)
        TabPadding.PaddingBottom = UDim.new(0, 10)
        TabPadding.PaddingLeft = UDim.new(0, 5)
        TabPadding.PaddingRight = UDim.new(0, 5)
        TabPadding.Parent = TabContent

        local function Activate()
            if ActiveTab then
                CreateTween(ActiveTab.Btn, "BackgroundColor3", USHINOU.Theme.Dark, 0.3)
                ActiveTab.Btn.TextColor3 = Color3.fromRGB(180, 180, 180)
                ActiveTab.Indicator.Visible = false
                ActiveTab.Content.Visible = false
            end
            CreateTween(TabBtn, "BackgroundColor3", Color3.fromRGB(60, 0, 0), 0.3)
            TabBtn.TextColor3 = USHINOU.Theme.Accent
            Indicator.Visible = true
            TabContent.Visible = true
            ActiveTab = {Btn = TabBtn, Indicator = Indicator, Content = TabContent}
            TabContent.CanvasSize = UDim2.new(0, 0, 0, TabContentLayout.AbsoluteContentSize.Y + 20)
        end

        TabBtn.MouseButton1Click:Connect(Activate)

        if not ActiveTab then
            task.delay(0.8, function()
                CreateTween(TabBtn, "BackgroundTransparency", 0, 0.3)
                CreateTween(TabBtn, "TextTransparency", 0, 0.3)
                if TabIcon then
                    for _, Child in ipairs(TabBtn:GetChildren()) do
                        if Child:IsA("ImageLabel") then
                            CreateTween(Child, "ImageTransparency", 0, 0.3)
                        end
                    end
                end
                Activate()
            end)
        else
            task.delay(0.8, function()
                CreateTween(TabBtn, "BackgroundTransparency", 0.7, 0.3)
                CreateTween(TabBtn, "TextTransparency", 0.2, 0.3)
                if TabIcon then
                    for _, Child in ipairs(TabBtn:GetChildren()) do
                        if Child:IsA("ImageLabel") then
                            CreateTween(Child, "ImageTransparency", 0.2, 0.3)
                        end
                    end
                end
            end)
        end

        TabScroll.CanvasSize = UDim2.new(0, 0, 0, TabLayout.AbsoluteContentSize.Y + 10)

        local Tab = {}

        function Tab:AddSection(Text)
            return CreateLabel(TabContent, {Text = Text, Size = 14, Color = USHINOU.Theme.Accent, Alignment = Enum.TextXAlignment.Center})
        end

        function Tab:AddLabel(Text)
            return CreateLabel(TabContent, {Text = Text})
        end

        function Tab:AddButton(Config)
            return CreateButton(TabContent, Config)
        end

        function Tab:AddToggle(Config)
            return CreateToggle(TabContent, Config)
        end

        function Tab:AddSlider(Config)
            return CreateSlider(TabContent, Config)
        end

        function Tab:AddDropdown(Config)
            return CreateDropdown(TabContent, Config)
        end

        function Tab:AddTextBox(Config)
            return CreateTextBox(TabContent, Config)
        end

        function Tab:AddKeybind(Config)
            return CreateKeybind(TabContent, Config)
        end

        function Tab:AddColorPicker(Config)
            return CreateColorPicker(TabContent, Config)
        end

        function Tab:AddParagraph(Config)
            return CreateParagraph(TabContent, Config)
        end

        function Tab:AddDiscordInvite(Config)
            return CreateDiscordInvite(TabContent, Config)
        end

        return Tab
    end

    function Window:Destroy()
        CreateTween(MainFrame, "Size", UDim2.new(0, 0, 0, 0), 0.5, true)
        CreateTween(MainFrame, "BackgroundTransparency", 1, 0.5)
        task.wait(0.5)
        ScreenGui:Destroy()
    end

    function Window:Minimize()
        MinimizeWindow()
    end

    function Window:Dialog(Config)
        local DialogFrame = Instance.new("Frame")
        DialogFrame.Parent = ScreenGui
        DialogFrame.Size = UDim2.new(0, 0, 0, 0)
        DialogFrame.Position = UDim2.new(0.5, 0, 0.5, 0)
        DialogFrame.AnchorPoint = Vector2.new(0.5, 0.5)
        DialogFrame.BackgroundColor3 = USHINOU.Theme.Dark
        DialogFrame.ZIndex = 100
        CreateCorner(DialogFrame, UDim.new(0, 12))
        AddMovingBorder(DialogFrame, 2)
        local DTitle = Instance.new("TextLabel")
        DTitle.Parent = DialogFrame
        DTitle.Size = UDim2.new(1, 0, 0, 30)
        DTitle.Position = UDim2.new(0, 0, 0, 10)
        DTitle.BackgroundTransparency = 1
        DTitle.Text = Config.Title or "Dialog"
        DTitle.TextColor3 = USHINOU.Theme.Accent
        DTitle.Font = Enum.Font.GothamBold
        DTitle.TextSize = 16
        local DText = Instance.new("TextLabel")
        DText.Parent = DialogFrame
        DText.Size = UDim2.new(1, -20, 0, 50)
        DText.Position = UDim2.new(0, 10, 0, 45)
        DText.BackgroundTransparency = 1
        DText.Text = Config.Text or "Are you sure?"
        DText.TextColor3 = USHINOU.Theme.Text
        DText.Font = Enum.Font.Gotham
        DText.TextSize = 12
        DText.TextWrapped = true
        local ButtonsFrame = Instance.new("Frame")
        ButtonsFrame.Parent = DialogFrame
        ButtonsFrame.Size = UDim2.new(1, 0, 0, 35)
        ButtonsFrame.Position = UDim2.new(0, 0, 1, -10)
        ButtonsFrame.AnchorPoint = Vector2.new(0, 1)
        ButtonsFrame.BackgroundTransparency = 1
        local ButtonsLayout = Instance.new("UIListLayout")
        ButtonsLayout.Parent = ButtonsFrame
        ButtonsLayout.FillDirection = Enum.FillDirection.Horizontal
        ButtonsLayout.HorizontalAlignment = Enum.HorizontalAlignment.Center
        ButtonsLayout.Padding = UDim.new(0, 10)
        local Options = Config.Options or {{"Yes", function() end}, {"No", function() end}}
        for _, Option in ipairs(Options) do
            local Btn = Instance.new("TextButton")
            Btn.Parent = ButtonsFrame
            Btn.Size = UDim2.new(0, 80, 0, 30)
            Btn.BackgroundColor3 = USHINOU.Theme.Accent
            Btn.Text = Option[1]
            Btn.TextColor3 = Color3.new(1, 1, 1)
            Btn.Font = Enum.Font.GothamBold
            Btn.TextSize = 12
            CreateCorner(Btn, UDim.new(0, 6))
            Btn.MouseButton1Click:Connect(function()
                if Option[2] then Option[2]() end
                CreateTween(DialogFrame, "Size", UDim2.new(0, 0, 0, 0), 0.3, true)
                task.wait(0.3)
                DialogFrame:Destroy()
            end)
        end
        CreateTween(DialogFrame, "Size", UDim2.new(0, 300, 0, 150), 0.5, true)
        return {
            Close = function() 
                CreateTween(DialogFrame, "Size", UDim2.new(0, 0, 0, 0), 0.3, true)
                task.wait(0.3)
                DialogFrame:Destroy() 
            end
        }
    end

    function Window:Notify(Config)
        local Notification = Instance.new("Frame")
        Notification.Parent = ScreenGui
        Notification.Size = UDim2.new(0, 0, 0, 80)
        Notification.Position = UDim2.new(0.5, 0, 0.9, 0)
        Notification.AnchorPoint = Vector2.new(0.5, 0.5)
        Notification.BackgroundColor3 = USHINOU.Theme.Dark
        Notification.BackgroundTransparency = 0.1
        Notification.ZIndex = 200
        CreateCorner(Notification, UDim.new(0, 10))
        AddMovingBorder(Notification, 1.5)
        local NTitle = Instance.new("TextLabel")
        NTitle.Parent = Notification
        NTitle.Size = UDim2.new(1, -20, 0, 25)
        NTitle.Position = UDim2.new(0, 10, 0, 5)
        NTitle.BackgroundTransparency = 1
        NTitle.Text = Config.Title or "Notification"
        NTitle.TextColor3 = USHINOU.Theme.Accent
        NTitle.Font = Enum.Font.GothamBold
        NTitle.TextSize = 14
        local NContent = Instance.new("TextLabel")
        NContent.Parent = Notification
        NContent.Size = UDim2.new(1, -20, 0, 45)
        NContent.Position = UDim2.new(0, 10, 0, 30)
        NContent.BackgroundTransparency = 1
        NContent.Text = Config.Content or "Content"
        NContent.TextColor3 = USHINOU.Theme.Text
        NContent.Font = Enum.Font.Gotham
        NContent.TextSize = 11
        NContent.TextWrapped = true
        CreateTween(Notification, "Size", UDim2.new(0, 300, 0, 80), 0.7, true)
        task.delay(Config.Duration or 3, function()
            CreateTween(Notification, "Size", UDim2.new(0, 0, 0, 80), 0.5, true)
            CreateTween(Notification, "BackgroundTransparency", 1, 0.5)
            CreateTween(NTitle, "TextTransparency", 1, 0.5)
            CreateTween(NContent, "TextTransparency", 1, 0.5)
            task.wait(0.5)
            Notification:Destroy()
        end)
        return {
            Destroy = function()
                CreateTween(Notification, "Size", UDim2.new(0, 0, 0, 80), 0.5, true)
                task.wait(0.5)
                Notification:Destroy()
            end
        }
    end

    return Window
end

return USHINOU
