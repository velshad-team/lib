local ShieldParts = {}

local function GetParts()
    local found = {}
    for _, v in pairs(workspace:GetDescendants()) do
        if v:IsA("BasePart") and not v.Anchored and (v.Name:lower():find("door") or v.Size.Y > 5) then
            if not v:IsDescendantOf(LP.Character) then
                table.insert(found, v)
                if #found >= 2 then break end -- نحتاج قطعتين لعمل الفتحة
            end
        end
    end
