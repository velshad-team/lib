task.spawn(function()
    local iHair, iName, iBio, iBody = 1, 1, 1, 1
    while true do
        local player = game.Players.LocalPlayer
        local RE = game:GetService("ReplicatedStorage"):FindFirstChild("RE")

        if player and player.Character then

            if isHairActive and RE and RE:FindFirstChild("1Max1y") then
                RE["1Max1y"]:FireServer("ChangeHairColor2", hairColors[iHair])
                iHair = iHair % #hairColors + 1
            end


            if isNameActive and RE and RE:FindFirstChild("1RPNam1eColo1r") then
                RE["1RPNam1eColo1r"]:FireServer("PickingRPNameColor", vibrantColors[iName])
                iName = iName % #vibrantColors + 1
            end


            if isBioActive and RE and RE:FindFirstChild("1RPNam1eColo1r") then
                RE["1RPNam1eColo1r"]:FireServer("PickingRPBioColor", vibrantColors[iBio])
                iBio = iBio % #vibrantColors + 1
            end


            if rgbEnabled then
                local Remotes = game:GetService("ReplicatedStorage"):FindFirstChild("Remotes")
                if Remotes and Remotes:FindFirstChild("ChangeBodyColor") then
                    Remotes.ChangeBodyColor:FireServer(bodyColors[iBody])
                    iBody = iBody % #bodyColors + 1
                end
            end
        end

        -- التحكم بالسرعة بناءً على القيمة المدخلة
        task.wait(1 / colorSpeed)
    end
end)
    end
})

