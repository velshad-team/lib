-- وظيفة الحقن الفيزيائي واحتلال الجسم
local function LaunchCore(level, animId, speed, power)
    local lp = game.Players.LocalPlayer
    local char = lp.Character
    if not char then return end
    local hum = char:FindFirstChildOfClass("Humanoid")
    if not hum then return end

    ResetSystem()

    -- تغيير شكل الجسم للسيطرة على الفيزياء (الاحتلال الشامل)
    local args = {[1] = 123402086843885, [2] = 100839513065432, [3] = 78300682916056, [4] = 86276701020724, [5] = 78409653958165, [6] = 15093053680}
    pcall(function()
        game:GetService("ReplicatedStorage").Remotes.ChangeCharacterBody:InvokeServer(args)
    end)

    task.wait(0.2)

    -- تحميل قوة الأنميشن (The Core)
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://" .. animId
    currentAnim = hum:LoadAnimation(anim)
    currentAnim.Priority = Enum.AnimationPriority.Action4
    currentAnim:Play(0.1, 1, speed)

    -- تثبيت الصلابة (Rigid State)
    local plank = Instance.new("Animation")
    plank.AnimationId = "rbxassetid://3695333486"
    currentRigid = hum:LoadAnimation(plank)
    currentRigid.Priority = Enum.AnimationPriority.Movement
    currentRigid:Play(0.1, 1, 0)

    -- القوة السابعة: اهتزاز الخريطة الشامل
    if level == 7 then
        task.spawn(function()
            while activeCore == 7 do
                -- قوة احتلال الماب (تأرجح فيزيائي FE)
                pcall(function()
                    char.HumanoidRootPart.Velocity = Vector3.new(math.random(-power, power), power, math.random(-power, power))
                end)
                task.wait(0.01)
            end
        end)
    end
end

