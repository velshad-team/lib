local FadeTween = TweenInfo.new(0.3, Enum.EasingStyle.Quad, Enum.EasingDirection.Out)

local function Create(instanceType, parent, properties)
    local instance = Instance.new(instanceType)
    if parent then instance.Parent = parent end
    if properties then
        for prop, value in pairs(properties) do
            instance[prop] = value
        end
    end
    return instance
end

local function Tween(instance, properties, duration, easingStyle, easingDirection, callback)
    easingStyle = easingStyle or Enum.EasingStyle.Quint
    easingDirection = easingDirection or Enum.EasingDirection.Out
    duration = duration or 0.4
    
    local tweenInfo = TweenInfo.new(duration, easingStyle, easingDirection)
    local tween = TweenService:Create(instance, tweenInfo, properties)
    
    if callback then
        tween.Completed:Connect(callback)
    end
    
    tween:Play()
    return tween
end

local function AddFadeClickEffect(button, targetTransparency)
    targetTransparency = targetTransparency or 0.3
    local originalTransparency = button.BackgroundTransparency
    
    button.MouseButton1Click:Connect(function()
        TweenService:Create(button, FadeTween, {
            BackgroundTransparency = targetTransparency
        }):Play()
        
        task.delay(0.2, function()
            TweenService:Create(button, FadeTween, {
                BackgroundTransparency = originalTransparency
            }):Play()
        end)
    end)
end

local function ApplyTheme(instance, elementType)
    local theme = VelShadLib.CurrentTheme
    
    if elementType == "Background" then
        instance.BackgroundColor3 = theme.Background
    elseif elementType == "Surface" then
        instance.BackgroundColor3 = theme.Surface
    elseif elementType == "Primary" then
        instance.BackgroundColor3 = theme.Primary
    elseif elementType == "Dark" then
        instance.BackgroundColor3 = theme.Dark
    elseif elementType == "Text" then
        instance.TextColor3 = theme.Text
    elseif elementType == "TextDark" then
        instance.TextColor3 = theme.TextDark
    elseif elementType == "Stroke" then
        instance.Color = theme.Stroke
    elseif elementType == "Gradient" then
        instance.Color = theme.Gradient
    elseif elementType == "Accent" then
        instance.BackgroundColor3 = theme.Accent
    end
end

local function InsertTheme(instance, type)
    table.insert(VelShadLib.Instances, {
        Instance = instance,
        Type = type
    })
    ApplyTheme(instance, type)
    return instance
end

local function MakeDraggable(frame, dragHandle)
    dragHandle = dragHandle or frame
    
    local dragging = false
    local dragInput, dragStart, startPos
    
    dragHandle.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            dragging = true
            dragStart = input.Position
            startPos = frame.Position
            
            input.Changed:Connect(function()
                if input.UserInputState == Enum.UserInputState.End then
                    dragging = false
                end
            end)
        end
    end)
    
    dragHandle.InputChanged:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then
            dragInput = input
        end
    end)
    
    UserInputService.InputChanged:Connect(function(input)
        if input == dragInput and dragging then
            local delta = input.Position - dragStart
            frame.Position = UDim2.new(
                startPos.X.Scale, startPos.X.Offset + delta.X,
                startPos.Y.Scale, startPos.Y.Offset + delta.Y
            )
        end
    end)
end

local function AddRipple(button, color)
    button.ClipsDescendants = true
    
    button.InputBegan:Connect(function(input)
        if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
            local ripple = Create("Frame", button, {
                AnchorPoint = Vector2.new(0.5, 0.5),
                BackgroundColor3 = color or Color3.fromRGB(255, 255, 255),
                BackgroundTransparency = 0.6,
                Position = UDim2.new(0, input.Position.X - button.AbsolutePosition.X, 0, input.Position.Y - button.AbsolutePosition.Y),
                Size = UDim2.new(0, 0, 0, 0),
                BorderSizePixel = 0,
                ZIndex = 10
            })
            
            Create("UICorner", ripple, {CornerRadius = UDim.new(1, 0)})
            
            local targetSize = math.max(button.AbsoluteSize.X, button.AbsoluteSize.Y) * 2
            
            Tween(ripple, {
                Size = UDim2.new(0, targetSize, 0, targetSize),
                BackgroundTransparency = 1
            }, 0.6, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, function()
                ripple:Destroy()
            end)
        end
    end)
end

