        OptBtn.MouseEnter:Connect(function()
            CreateTween(OptBtn, "BackgroundColor3", Color3.fromRGB(60, 0, 0), 0.2)
        end)
        
        OptBtn.MouseLeave:Connect(function()
            CreateTween(OptBtn, "BackgroundColor3", Color3.fromRGB(30, 0, 0), 0.2)
        end)
    end
    
    Scroll.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 10)
    
    Button.MouseButton1Click:Connect(function()
        Open = not Open
        if Open then
            OptionsFrame.Visible = true
            CreateTween(Frame, "Size", UDim2.new(1, 0, 0, 35 + math.min(150, Layout.AbsoluteContentSize.Y + 10)), 0.3)
            CreateTween(Arrow, "Rotation", 0, 0.3)
        else
