        Callback(Option)
        CreateTween(Frame, "Size", UDim2.new(1, 0, 0, 35), 0.3)
        CreateTween(Arrow, "Rotation", 90, 0.3)
        Open = false
        task.delay(0.3, function() OptionsFrame.Visible = false end)
    end
    
