local function CreateKillerTool()
    local _Tool = Instance.new('Tool')
    _Tool.Name = '9MART KILLER ☠️'
    _Tool.RequiresHandle = false
    _Tool.Parent = _LP.Backpack

    local u4 = nil
    local active = false
    local parts = {}

    -- وظيفة جلب "الضحايا" (القطع الكبيرة أو الأبواب)
    local function GetParts()
        local found = {}
        for _, v in pairs(workspace:GetDescendants()) do
            if v:IsA("BasePart") and not v.Anchored and not v:IsDescendantOf(_LP.Character) then
                if v.Name:lower():find("door") or v.Name:lower():find("court") or v.Size.Magnitude > 5 then
                    table.insert(found, v)
                    if #found >= 3 then break end
                end
            end
        end
        return found
    end

    _Tool.Equipped:Connect(function()
        active = true
        parts = GetParts()
        local _Hum = (_LP.Character or _LP.CharacterAdded:Wait()):FindFirstChildOfClass('Humanoid')
        
        if _Hum then
            local _Anim = Instance.new('Animation')
            _Anim.AnimationId = u1
            u4 = _Hum:LoadAnimation(_Anim)
            u4.Looped = true
            u4:Play()
            u4:AdjustSpeed(0.5)
        end
    end)

    _Tool.Unequipped:Connect(function()
        active = false
        if u4 then u4:Stop() u4 = nil end
        parts = {}
    end)

    -- محرك القتل (يعمل فقط عند مسك الأداة)
    RS.Heartbeat:Connect(function()
        if active and _LP.Character and _LP.Character:FindFirstChild("HumanoidRootPart") then
            local Root = _LP.Character.HumanoidRootPart
            sethiddenproperty(_LP, "SimulationRadius", 1e10)
            
            local t = tick() * 90 -- سرعة دوران خرافية
            
            for i, p in pairs(parts) do
                if p and p.Parent then
                    p.CanCollide = true
                    -- سرعة قتل FE حقيقية
                    p.Velocity = Vector3.new(1e32, 1e32, 1e32)
                    p.RotVelocity = Vector3.new(1e32, 1e32, 1e32)
                    
                    -- حماية خليفة (الفتحة المركزية)
                    for _, cp in pairs(_LP.Character:GetDescendants()) do
                        if cp:IsA("BasePart") then
                            local nc = cp:FindFirstChild("9M_NC") or Instance.new("NoCollisionConstraint", cp)
                            nc.Part0 = cp; nc.Part1 = p; nc.Name = "9M_NC"
                        end
                    end
                    
                    -- دوران الأبواب حول البطن
                    local angle = t + (i * (math.pi * 2 / #parts))
                    local offset = Vector3.new(math.cos(angle) * 5, 0, math.sin(angle) * 5)
                    p.CFrame = Root.CFrame * CFrame.new(offset) * CFrame.Angles(0, -angle, math.rad(90))
                end
            end
        end
    end)
end

