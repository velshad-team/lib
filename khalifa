local function StartAction(mode, yOff, face)
    if CurrentConnection then CurrentConnection:Disconnect() end
    local char = LocalPlayer.Character
    local root = char.HumanoidRootPart
    local hum = char.Humanoid
    
    hum.PlatformStand = true
    -- تعطيل التصادم (مضاد للمضادات 100%)
    for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end

    CurrentConnection = RunService.Heartbeat:Connect(function()
        if not getgenv().selectedPlayer then return end
        local target = Players:FindFirstChild(getgenv().selectedPlayer)
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            local tRoot = target.Character.HumanoidRootPart
            local tHead = target.Character:FindFirstChild("Head") or tRoot
            
            -- تصفير القوى الفيزيائية (منع الطرد)
            root.Velocity = Vector3.new(0,0,0)
            root.RotVelocity = Vector3.new(0,0,0)

            local time = tick() * 20 -- سرعة الحركة
            
            if mode == "Bang" then
                local offset = (math.sin(tick()*50) > 0 and 0.5 or 2.5)
                local side = face and -1 or 1
                local cf = tRoot.CFrame * CFrame.new(0, yOff, offset * side)
                if face then cf = cf * CFrame.Angles(0, math.rad(180), 0) end
                char:SetPrimaryPartCFrame(cf)
                
            elseif mode == "Spin" then -- دوران إعصاري
                local dist = 3
                char:SetPrimaryPartCFrame(tRoot.CFrame * CFrame.new(math.cos(time)*dist, 0, math.sin(time)*dist) * CFrame.Angles(0, -time, 0))
                
            elseif mode == "Side" then -- وقوف استعراضي
                char:SetPrimaryPartCFrame(tRoot.CFrame * CFrame.new(3, 0, 0) * CFrame.Angles(0, math.rad(90), 0))
                
            elseif mode == "Jalg" then -- دالة الجلق (أمام الوجه)
                local shake = math.sin(tick()*80) * 0.8
                char:SetPrimaryPartCFrame(tHead.CFrame * CFrame.new(0, -0.5, -1.2 + shake) * CFrame.Angles(math.rad(90), math.rad(180), 0))
            end
        end
    end)
end

