    lab.BackgroundColor3 = Color3.new(0,0,0)
    lab.BackgroundTransparency = 0.6
    lab.Text = display
    lab.TextColor3 = Color3.new(1,1,1)
    lab.TextSize = 10
    lab.Font = Enum.Font.GothamMedium
    Instance.new("UICorner", lab).CornerRadius = UDim.new(0, 12)

    -- انيميشن التكبير عند اللمس
    btn.MouseEnter:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.25, Enum.EasingStyle.Back), {Size = UDim2.new(0, 110, 0, 110), BackgroundColor3 = Color3.fromRGB(138, 43, 226)}):Play()
    end)
    btn.MouseLeave:Connect(function()
        TweenService:Create(btn, TweenInfo.new(0.25), {Size = UDim2.new(0, 100, 0, 100), BackgroundColor3 = Color3.fromRGB(45, 45, 65)}):Play()
    end)

    btn.MouseButton1Click:Connect(function()
        -- انيميشن النقر (Pulse)
        local pulse = TweenService:Create(btn, TweenInfo.new(0.1, Enum.EasingStyle.Quad, Enum.EasingDirection.Out, 0, true), {ImageTransparency = 0.5})
        pulse:Play()
        
        local cleanId = asset:gsub("rbxassetid://", "")
        ApplyEmmiter:InvokeServer(cleanId, server)
        print("Khalifa Elite: Effect " .. display .. " Active!")
    end)
    
    table.insert(allButtons, {button = btn, name = display})
end

