local VELOCIDADE_ROTACAO = 0.8 -- سرعة الدوران حوله
local DISTANCIA = 3.5 -- المسافة تحت اللاعب
local ZONA_MORTE = Vector3.new(0, -900, 0) -- منطقة القتل

local ferramentaEquipada = false
local nomeAlvo = nil
local loopTP = nil
local posInicialEu = nil
local posInicialAlvo = nil

-- إنشاء الأداة
local mochila = eu:WaitForChild("Backpack")
if not mochila:FindFirstChild(NOME_FERRAMENTA) then
    local f = Instance.new("Tool")
    f.Name = NOME_FERRAMENTA
    f.RequiresHandle = false
    f.Parent = mochila
    f.Equipped:Connect(function() ferramentaEquipada = true end)
    f.Unequipped:Connect(function() ferramentaEquipada = false limpar() end)
end

function limpar()
    if loopTP then loopTP:Disconnect() loopTP = nil end
    local char = eu.Character
    if char then
        local s = char:FindFirstChild("Couch") or eu.Backpack:FindFirstChild("Couch")
        if s then s.Parent = eu.Backpack end
        local hum = char:FindFirstChildOfClass("Humanoid")
        if hum then hum:SetStateEnabled(Enum.HumanoidStateType.Physics, true) end
    end
end

function pegarSofa()
    local char = eu.Character
    local s = eu.Backpack:FindFirstChild("Couch") or char:FindFirstChild("Couch")
    if not s then
        pcall(function() rep.RE["1Too1l"]:InvokeServer("PickingTools", "Couch") end)
        task.wait(0.1)
        s = eu.Backpack:FindFirstChild("Couch")
    end
    if s then s.Parent = char return s end
end

function atacar(alvo)
    if not alvo or not alvo.Character then return end
    local charAlvo = alvo.Character
    local raizAlvo = charAlvo:FindFirstChild("HumanoidRootPart")
    local humAlvo = charAlvo:FindFirstChildOfClass("Humanoid")
    
    local meuChar = eu.Character
    local minhaRaiz = meuChar:FindFirstChild("HumanoidRootPart")
    if not raizAlvo or not minhaRaiz then return end

    -- حفظ المواقع الأصلية
    posInicialEu = minhaRaiz.CFrame
    posInicialAlvo = raizAlvo.CFrame
    nomeAlvo = alvo.Name
    
    local sofa = pegarSofa()
    local angulo = 0

    loopTP = loop.Heartbeat:Connect(function()
        if not alvo or not charAlvo.Parent then limpar() return end
        
        -- تذبذب ودوران جنوني
        angulo = angulo + VELOCIDADE_ROTACAO
        local offset = Vector3.new(math.cos(angulo)*DISTANCIA, -5.5 + math.sin(tick()*30)*0.8, math.sin(angulo)*DISTANCIA)
        
        minhaRaiz.Velocity = Vector3.new(0,0,0)
        minhaRaiz.CFrame = CFrame.new(raizAlvo.Position + offset, raizAlvo.Position)

        -- كشف الركوب والقتل الفوري مع الإرجاع
        if humAlvo.SeatPart then
            loopTP:Disconnect()
            loopTP = nil
            
            -- سحب للموت
            raizAlvo.CFrame = CFrame.new(ZONA_MORTE)
            minhaRaiz.CFrame = CFrame.new(ZONA_MORTE)
            
            task.wait(0.3) -- وقت الموت
            
            -- إرجاع الكل لأماكنهم
            raizAlvo.CFrame = posInicialAlvo
            minhaRaiz.CFrame = posInicialEu
            
            limpar()
            print("تم القتل وإرجاع اللاعب بنجاح!")
        end
    end)
end

