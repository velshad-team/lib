local function CreateTween(Instance, Prop, NewVal, Time, WaitEnd)
    local Tween = TweenService:Create(Instance, TweenInfo.new(Time or 0.3, Enum.EasingStyle.Quint), {[Prop] = NewVal})
    Tween:Play()
    if WaitEnd then Tween.Completed:Wait() end
    return Tween
end

local function MakeDrag(Instance)
    local Dragging, DragStart, StartPos = false, nil, nil
    Instance.InputBegan:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
            Dragging = true
            DragStart = Input.Position
            StartPos = Instance.Position
        end
    end)
    UserInputService.InputChanged:Connect(function(Input)
        if Dragging and (Input.UserInputType == Enum.UserInputType.MouseMovement or Input.UserInputType == Enum.UserInputType.Touch) then
            local Delta = Input.Position - DragStart
            Instance.Position = UDim2.new(StartPos.X.Scale, StartPos.X.Offset + Delta.X, StartPos.Y.Scale, StartPos.Y.Offset + Delta.Y)
        end
    end)
    UserInputService.InputEnded:Connect(function(Input)
        if Input.UserInputType == Enum.UserInputType.MouseButton1 or Input.UserInputType == Enum.UserInputType.Touch then
            Dragging = false
        end
    end)
end

local function AddMovingBorder(Parent, Thickness, Speed)
    local Stroke = Instance.new("UIStroke")
    Stroke.Parent = Parent
    Stroke.Thickness = Thickness or 1.5
    Stroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
    Stroke.LineJoinMode = Enum.LineJoinMode.Round
    Stroke.Color = Color3.new(1, 1, 1)
    local Gradient = Instance.new("UIGradient")
    Gradient.Parent = Stroke
    Gradient.Color = ColorSequence.new({
        ColorSequenceKeypoint.new(0, USHINOU.Theme.Dark),
        ColorSequenceKeypoint.new(0.5, USHINOU.Theme.Accent),
        ColorSequenceKeypoint.new(1, USHINOU.Theme.Dark)
    })
    local Rotation = 0
    RunService.RenderStepped:Connect(function(Delta)
        Rotation = Rotation + (Delta * (Speed or 80))
        if Rotation >= 360 then Rotation = 0 end
        Gradient.Rotation = Rotation
    end)
    return Stroke
end

