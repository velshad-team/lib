local function Action(mode, y, f, sMult)
    if Loop then Loop:Disconnect() end
    local char = LP.Character
    local root = char.HumanoidRootPart
    char.Humanoid.PlatformStand = true
    for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end

    Loop = RS.RenderStepped:Connect(function()
        if not getgenv().Victim then return end
        local target = Players:FindFirstChild(getgenv().Victim)
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            local tRoot = target.Character.HumanoidRootPart
            local tHead = target.Character:FindFirstChild("Head") or tRoot
            root.Velocity, root.RotVelocity = Vector3.new(0,0,0), Vector3.new(0,0,0)
            
            local t = tick() * (100 * (sMult or 1))
            local shake = (math.sin(tick()*80) > 0 and 0.2 or 2.5)

            if mode == "Jalg" then -- أنماط الجلق الـ 10
                local off = (y == 1 and math.sin(t)*0.9 or math.cos(t)*0.8)
                char:SetPrimaryPartCFrame(tHead.CFrame * CFrame.new(0, -0.5, -1.1 + off) * CFrame.Angles(math.rad(90), math.rad(180), 0))
            
            elseif mode == "Psycho" then -- سيكو عالمي
                local pShake = Vector3.new(math.random(-2,2), math.random(-2,2), math.random(-2,2)) * 0.5
                local side = f and -1 or 1
                char:SetPrimaryPartCFrame(tRoot.CFrame * CFrame.new(pShake.X, y, (shake * side) + pShake.Z) * (f and CFrame.Angles(0, math.rad(180), 0) or CFrame.Angles(t,t,t)))
            
            elseif mode == "Warrior" then -- وضعية المحارب (قوس)
                char:SetPrimaryPartCFrame(tRoot.CFrame * CFrame.new(4, 0, 0) * CFrame.Angles(0, math.rad(90), 0))
                -- انميشن وهمي للقوس
                char.HumanoidRootPart.CFrame = char.HumanoidRootPart.CFrame * CFrame.Angles(math.rad(45), 0, 0)
            end
        end
    end)
end

