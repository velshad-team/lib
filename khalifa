local function CreateDropdown(parent, pos)
    local dBtn = Instance.new("TextButton", parent)
    dBtn.Size = UDim2.new(0.9, 0, 0, 45)
    dBtn.Position = pos
    dBtn.Text = "قائمة الأهداف ▼"
    dBtn.BackgroundColor3 = Color3.fromRGB(40, 0, 0)
    dBtn.TextColor3 = Color3.new(1,1,1)
    dBtn.Font = "GothamBold"
    Instance.new("UICorner", dBtn)

    local list = Instance.new("ScrollingFrame", parent)
    list.Size = UDim2.new(0.9, 0, 0, 160)
    list.Position = UDim2.new(pos.X.Scale, pos.X.Offset, pos.Y.Scale, pos.Y.Offset + 50)
    list.Visible = false
    list.ZIndex = 20
    list.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
    list.BorderSizePixel = 0
    Instance.new("UIListLayout", list).Padding = UDim.new(0, 5)
    Instance.new("UICorner", list)

    dBtn.MouseButton1Click:Connect(function()
        list.Visible = not list.Visible
        for _,v in pairs(list:GetChildren()) do if v:IsA("TextButton") then v:Destroy() end end
        for _,p in pairs(Players:GetPlayers()) do
            local b = Instance.new("TextButton", list)
            b.Size = UDim2.new(1, 0, 0, 35)
            b.Text = "  " .. p.Name
            b.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
            b.TextColor3 = Color3.fromRGB(255, 255, 255)
            b.Font = "GothamMedium"
            b.TextXAlignment = "Left"
            b.ZIndex = 21
            Instance.new("UICorner", b)
            b.MouseButton1Click:Connect(function()
                list.Visible = false
                dBtn.Text = "المختار: " .. p.Name
                UpdateSelection(p)
            end)
        end
    end)
end

