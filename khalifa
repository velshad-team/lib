local function getDecoratedName()
    if playerName == "" then return "" end
    local tbl = decorations[decorationStyle] or decorations["نمط 1"]
    local result = ""
    

    for c in playerName:gmatch("[%z\1-\127\194-\244][\128-\191]*") do
        result = result .. (tbl[c] or c)
    end
    

    local sym = symbols[selectedSymbol] or symbols["بدون"]
    return sym.left .. result .. sym.right
end

