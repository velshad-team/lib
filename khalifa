local function Samla(mode, sub)
    if Loop then Loop:Disconnect() end
    local char = LP.Character
    char.Humanoid.PlatformStand = true
    for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end

    Loop = RS.RenderStepped:Connect(function()
        if not getgenv().Victim then return end
        local target = game.Players:FindFirstChild(getgenv().Victim)
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            local tRoot = target.Character.HumanoidRootPart
            local tHead = target.Character:FindFirstChild("Head") or tRoot
            char.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
            local t = tick() * 120
            
            -- [ الفصل الفيزيائي للوضعيات ] --
            if mode == "JFront" then -- جلق أمامي (تركيز على اليد والحلق)
                char:SetPrimaryPartCFrame(tHead.CFrame * CFrame.new(0, -0.8 + (sub*0.1), -1.1 + math.sin(t)*0.7) * CFrame.Angles(math.rad(90), math.rad(180), 0))
            elseif mode == "JBack" then -- جلق خلفي (تركيز على اليد والخصر)
                char:SetPrimaryPartCFrame(tRoot.CFrame * CFrame.new(0, -1.6, 1.3 + math.sin(t)*0.7) * CFrame.Angles(math.rad(-90), 0, 0))
            elseif mode == "PButt" then -- قبض الطيـ/ـز (زاوية انحناء)
                char:SetPrimaryPartCFrame(tRoot.CFrame * CFrame.new(math.sin(t*0.5)*0.2, -1.3, 0.7 + (sub*0.1)) * CFrame.Angles(math.rad(45 + sub), 0, 0))
            elseif mode == "PHead" then -- قبض الرأس (إجبار المص)
                char:SetPrimaryPartCFrame(tHead.CFrame * CFrame.new(0, -0.3, -1.4) * CFrame.Angles(math.rad(100 + sub), math.rad(180), 0))
            elseif mode == "HBack" then -- شبق خلفي (التصاق عميق)
                char:SetPrimaryPartCFrame(tRoot.CFrame * CFrame.new(0, -0.2, 0.4 + (sub*0.1)) * CFrame.Angles(math.rad(sub*2), 0, 0))
            elseif mode == "HFront" then -- شبق أمامي (إيلاج حلق)
                char:SetPrimaryPartCFrame(tHead.CFrame * CFrame.new(0, -0.6, -0.5 + (sub*0.1)) * CFrame.Angles(0, math.rad(180), 0))
            elseif mode == "Spin" then -- دوران إجرامي
                char:SetPrimaryPartCFrame(tRoot.CFrame * CFrame.new(math.cos(t/6)*5, 2, math.sin(t/6)*5) * CFrame.Angles(0,-t,0))
            end
        end
    end)
end

