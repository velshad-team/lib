local function makeEliteButton(display, asset, server)
    local btn = Instance.new("ImageButton", scroll)
    btn.BackgroundColor3 = Color3.fromRGB(45, 45, 65)
    btn.Image = asset
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 12)
    
