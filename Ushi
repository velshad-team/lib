            CreateTween(Arrow, "Rotation", 90, 0.3)
            task.delay(0.3, function() OptionsFrame.Visible = false end)
        end
    end)
    
    if Selected then SelectOption(Selected) end
    
    return {
        Frame = Frame,
        Set = SelectOption,
        Add = function(Option)
            local OptBtn = Instance.new("TextButton")
            OptBtn.Parent = Scroll
            OptBtn.Size = UDim2.new(1, 0, 0, 28)
            OptBtn.BackgroundColor3 = Color3.fromRGB(30, 0, 0)
            OptBtn.Text = tostring(Option)
            OptBtn.Font = Enum.Font.GothamBold
            OptBtn.TextSize = 11
            OptBtn.TextColor3 = USHINOU.Theme.Text
            CreateCorner(OptBtn, UDim.new(0, 6))
            
            OptBtn.MouseButton1Click:Connect(function()
                SelectOption(Option)
            end)
            
            Scroll.CanvasSize = UDim2.new(0, 0, 0, Layout.AbsoluteContentSize.Y + 10)
        end,
        Destroy = function() Frame:Destroy() end
    }
end

