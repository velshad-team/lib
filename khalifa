-- [[ المحرك النووي V57 ]] --
local function Samla(mode, y, f, sM)
    if Loop then Loop:Disconnect() end
    local char = LP.Character
    char.Humanoid.PlatformStand = true
    for _, v in pairs(char:GetDescendants()) do if v:IsA("BasePart") then v.CanCollide = false end end

    Loop = RS.RenderStepped:Connect(function()
        if not getgenv().Victim then return end
        local target = Players:FindFirstChild(getgenv().Victim)
        if target and target.Character and target.Character:FindFirstChild("HumanoidRootPart") then
            local tRoot = target.Character.HumanoidRootPart
            local tHead = target.Character:FindFirstChild("Head") or tRoot
            char.HumanoidRootPart.Velocity = Vector3.new(0,0,0)
            
            local t = tick() * (120 * (sM or 1))
            local shake = (math.sin(tick()*90) > 0 and 0.1 or 2.6)

            if mode == "Jalg" then
                char:SetPrimaryPartCFrame(tHead.CFrame * CFrame.new(0, -0.5, -1.1 + math.sin(t*y)*0.9) * CFrame.Angles(math.rad(90), math.rad(180), 0))
            elseif mode == "Psy" then
                char:SetPrimaryPartCFrame(tRoot.CFrame * CFrame.new(math.random(-1,1)*y, y, (shake*(f and -1 or 1))) * CFrame.Angles(t,t,t))
            elseif mode == "Bang" then
                char:SetPrimaryPartCFrame(tRoot.CFrame * CFrame.new(0, y, shake*(f and -1 or 1)) * (f and CFrame.Angles(0,math.rad(180),0) or CFrame.new()))
            elseif mode == "War" then
                char:SetPrimaryPartCFrame(tRoot.CFrame * CFrame.new(y, 0, 0) * CFrame.Angles(0, math.rad(90), 0) * CFrame.Angles(math.rad(30),0,0))
            elseif mode == "Extra" then
                if y == "Spin" then char:SetPrimaryPartCFrame(tRoot.CFrame * CFrame.new(math.cos(t/5)*4, 2, math.sin(t/5)*4) * CFrame.Angles(0,-t,0)) end
                if y == "Dog" then char:SetPrimaryPartCFrame(tRoot.CFrame * CFrame.new(0,-2,2.5) * CFrame.Angles(math.rad(90),0,0)) end
            end
        end
    end)
end

